# FounderConsole Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - These must be set for the application to run
# =============================================================================

# Database connection string
# PostgreSQL: postgresql://user:password@host:5432/founderconsole
# SQLite (dev only): sqlite:///./founderconsole.db
DATABASE_URL=postgresql://user:password@localhost:5432/founderconsole

# Secret key for JWT token signing (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string

# =============================================================================
# PRODUCTION REQUIRED - Must be set when ENVIRONMENT=production
# =============================================================================

# Comma-separated list of allowed CORS origins
# Example: https://app.founderconsole.com,https://www.founderconsole.com
CORS_ORIGINS=http://localhost:5000

# Admin master password hash (bcrypt)
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_MASTER_PASSWORD_HASH=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Server port
PORT=5000

# FastAPI internal port (used by Express gateway)
FASTAPI_PORT=8001

# Node environment
NODE_ENV=development

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT access token expiry in minutes (default: 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin/master token expiry in minutes (default: 30)
MASTER_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# RATE LIMITING (requests per minute)
# =============================================================================

# Auth endpoints (login/register)
RATE_LIMIT_AUTH=10

# Admin login endpoint (stricter)
RATE_LIMIT_ADMIN_LOGIN=3

# General API endpoints
RATE_LIMIT_API=60

# File upload endpoints
RATE_LIMIT_UPLOAD=5

# =============================================================================
# DATABASE CONNECTION POOL
# =============================================================================

# Connection pool size (ignored for SQLite)
DB_POOL_SIZE=10

# Max overflow connections beyond pool_size
DB_MAX_OVERFLOW=20

# Pool connection timeout in seconds
DB_POOL_TIMEOUT=30

# =============================================================================
# ENCRYPTION
# =============================================================================

# Salt for credential encryption (change in production)
ENCRYPTION_SALT=founderconsole-credential-salt-v1

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Whether to create database schema on startup
CREATE_SCHEMA=true

# Whether to run database migrations on startup
RUN_MIGRATIONS=true

# Whether to seed benchmark data on startup
SEED_BENCHMARKS=true

# Whether to seed demo data (demo@founderconsole.ai account)
SEED_DEMO_DATA=false

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# OpenAI API key for AI features
OPENAI_API_KEY=

# Anthropic API key for AI features
ANTHROPIC_API_KEY=

# SendGrid API key for email
SENDGRID_API_KEY=

# Twilio credentials for SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Notion integration
NOTION_API_KEY=

# Stripe for payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
